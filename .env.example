# Project (used by docker-compose)
PROJECT_NAME=news-backend

# MongoDB – app and docker-compose both use these
MONGO_IMAGE=mongo:7.0.14
MONGO_CONTAINER=news-mongodb
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=news
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGODB_AUTH_SOURCE=admin

# Valkey (Redis) – app and docker-compose both use these
VALKEY_IMAGE=valkey/valkey:7.2.5
VALKEY_CONTAINER=news-valkey
VALKEY_PORT=6379
VALKEY_URL=redis://localhost:6379

# LLM – set your key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# App
CACHE_BACKEND=valkey
MAX_RADIUS_KM=1500
